# Credenciales HubSpot (SPEC-0003)
HUBSPOT_ACCESS_TOKEN=

# Credenciales Google Drive (SPEC-0004)
# OAuth 2.0 con PKCE. El redirect es un loopback dinámico (http://127.0.0.1:<puerto>), no se configura.
# Estas variables son un FALLBACK opcional: lo normal es configurarlas en la app
# (Conectores → Google Drive). No se necesita API key: el selector de carpeta es propio (SPEC-0004 §14).
GOOGLE_CLIENT_ID=
# Opcional: solo si el client de OAuth es de tipo "Desktop app" y exige client_secret.
GOOGLE_CLIENT_SECRET=

# Auto-update (electron-builder / GitHub)
GH_TOKEN=
